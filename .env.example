# Scraper Provider
SCRAPER_PROVIDER=firecrawl
FIRECRAWL__API_KEY="your_firecrawl_api_key"

# OpenAI (khi LLM_PROVIDER=openai). Prefix OPENAI__
OPENAI__API_KEY="your_openai_api_key"
OPENAI__API_BASE=https://api.openai.com/v1
OPENAI__ALLOWED_MODELS=your_allowed_models_comma_separated
OPENAI__TEMPERATURE=0.3
OPENAI__REQUEST_TIMEOUT=60

# Anthropic (khi LLM_PROVIDER=anthropic). Prefix ANTHROPIC__
ANTHROPIC__API_KEY="your_anthropic_api_key"
ANTHROPIC__TEMPERATURE=0.3
ANTHROPIC__REQUEST_TIMEOUT=60

# Gemini (khi LLM_PROVIDER=gemini). Prefix GEMINI__
GEMINI__API_KEY="your_gemini_api_key"
GEMINI__TEMPERATURE=0.3
GEMINI__REQUEST_TIMEOUT=60

# Crew
CREW__RATE_LIMIT_MAX_REQUESTS=
CREW__RATE_LIMIT_WINDOW_SECONDS=
CREW__INFLIGHT_WAIT_TIMEOUT_SECONDS=
CREW__RESULT_CACHE_TTL_SECONDS=

# Postgres
POSTGRES__HOST="localhost"
POSTGRES__PORT=15432
POSTGRES__USER="your_postgres_user"
POSTGRES__PASSWORD="your_postgres_password"
POSTGRES__DB="your_postgres_db"
POSTGRES__CREATE_TABLES=true

# Authentication and CORS
AUTH__JWT_SECRET_KEY=your_jwt_secret_key
AUTH__REFRESH_COOKIE_SECURE=false
CORS__ALLOW_ORIGINS=http://<IP>:5173,http://127.0.0.1:5173
CORS__ALLOW_ORIGIN_REGEX=https?://(<IP>|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.\\d{1,3}\\.\\d{1,3}|10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2\\d|3[0-1])\\.\\d{1,3}\\.\\d{1,3})(:\\d+)?$

# Google Authentication
AUTH__GOOGLE_ENABLED=true
AUTH__GOOGLE_CLIENT_ID=205826881342-7qr733lt84b5f71ee05mcjs4q28smsn0.apps.googleusercontent.com
AUTH__GOOGLE_CLIENT_SECRET="your_google_client_secret"
AUTH__GOOGLE_REDIRECT_URI=http://<IP>:8000/api/v1/auth/google/callback
AUTH__GOOGLE_FE_SUCCESS_REDIRECT=http://<IP>:5173/login/google-callback
AUTH__GOOGLE_FE_ERROR_REDIRECT=http://<IP>:5173/login
AUTH__GOOGLE_STATE_TTL_SECONDS=300
AUTH__GOOGLE_STATE_COOKIE_SECURE=false

# LinkedIn OAuth (per-user publish)
AUTH__LINKEDIN_ENABLED=false
AUTH__LINKEDIN_CLIENT_ID=your_linkedin_client_id
AUTH__LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
AUTH__LINKEDIN_REDIRECT_URI=http://<IP>:8000/api/v1/social/linkedin/callback
AUTH__LINKEDIN_SCOPE=openid profile email w_member_social
AUTH__LINKEDIN_STATE_TTL_SECONDS=300
AUTH__LINKEDIN_FE_SUCCESS_REDIRECT=http://<IP>:5173/profile
AUTH__LINKEDIN_FE_ERROR_REDIRECT=http://<IP>:5173/profile
AUTH__SOCIAL_TOKEN_ENCRYPTION_KEY=replace_with_long_random_secret

# Facebook OAuth (per-user publish)
AUTH__FACEBOOK_ENABLED=true
AUTH__FACEBOOK_CLIENT_ID=your_facebook_client_id
AUTH__FACEBOOK_CLIENT_SECRET="your_facebook_client_secret"
AUTH__FACEBOOK_REDIRECT_URI=http://<IP>:8000/api/v1/social/facebook/callback
AUTH__FACEBOOK_SCOPE=pages_show_list pages_read_engagement pages_manage_posts
AUTH__FACEBOOK_STATE_TTL_SECONDS=300
AUTH__FACEBOOK_FE_SUCCESS_REDIRECT=http://<IP>:5173/profile
AUTH__FACEBOOK_FE_ERROR_REDIRECT=http://<IP>:5173/profile
